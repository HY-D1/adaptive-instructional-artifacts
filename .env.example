# SQL-Adapt Environment Variables
#
# IMPORTANT: Variables prefixed with VITE_ are embedded in the frontend bundle
# at BUILD TIME. Changing these on Vercel requires a REDEPLOYMENT to take effect.
#
# Copy this file to .env and customize for your environment.

# ============================================
# REQUIRED FOR PRODUCTION
# ============================================
# These MUST be set for production deployments.
# Without these, core features will be unavailable.

# Instructor passcode for accessing the instructor dashboard
# - Required for instructor role to function in production
# - Set this to match your current backend instructor signup contract
# - CHANGE THIS to a secure value in production!
VITE_INSTRUCTOR_PASSCODE=TEACHSQL2026

# ============================================
# OPTIONAL - LOCAL DEVELOPMENT ONLY
# ============================================
# These features require a backend or local services.
# They are NOT available on Vercel/static hosting.

# Ollama URL for LLM-powered explanations
# - Only works with local Ollama installation
# - NOT available on Vercel (no server-side code execution)
# - Default: http://127.0.0.1:11434
VITE_OLLAMA_URL=http://127.0.0.1:11434

# Enable LLM feature flag
# - Set to 'true' to enable LLM UI components
# - Still requires Ollama to be running locally
# - Default: false
VITE_ENABLE_LLM=false

# Enable Vercel Web Analytics runtime loading
# - Set to 'true' only when @vercel/analytics is installed and desired
# - Default: false (launch-safe)
VITE_ENABLE_VERCEL_ANALYTICS=false

# Enable Vercel Speed Insights component
# - Set to 'false' to disable
# - Default: true
VITE_ENABLE_VERCEL_SPEED_INSIGHTS=true

# Enable PDF index feature flag
# - Requires backend PDF processing (Poppler/pdftotext)
# - NOT available on static hosting
# - Default: false
VITE_ENABLE_PDF_INDEX=false

# Backend API URL (for full-stack mode)
# - Set when running with a backend server
# - Leave empty for same-origin (Vite dev proxy)
# - Example: https://api.sql-adapt.com
VITE_API_BASE_URL=

# ============================================
# BACKEND CONFIGURATION (Server-side)
# ============================================
# These are used by the backend server, not the frontend.
# Not applicable for Vercel/static hosting deployments.

# Server port (default: 3001)
PORT=3001

# CORS origin for frontend requests
CORS_ORIGIN=http://localhost:5173
# Optional exact allowlist for multiple frontend origins
# CORS_ORIGINS=https://app.example.com,https://www.example.com
# Optional wildcard allowlist for trusted preview domains
# CORS_ORIGIN_PATTERNS=https://your-project-*.vercel.app

# Neon PostgreSQL Database (REQUIRED for production persistence)
# Get your connection string from: https://neon.tech
# Format: postgresql://username:password@host/database?sslmode=require
DATABASE_URL=

# Node environment
NODE_ENV=development

# Enable PDF index on backend (requires Poppler)
ENABLE_PDF_INDEX=false

# PDF index storage directory
PDF_INDEX_DIR=./data/pdf-index

# Source PDF files directory
PDF_SOURCE_DIR=./data/pdfs

# Enable LLM proxy on backend
ENABLE_LLM=false

# Ollama base URL for backend
OLLAMA_BASE_URL=http://127.0.0.1:11434

# ============================================
# DEPLOYMENT EXAMPLES
# ============================================

# --- Local Development (Full Features) ---
# VITE_INSTRUCTOR_PASSCODE=TEACHSQL2026
# VITE_ENABLE_PDF_INDEX=true
# VITE_ENABLE_LLM=true
# VITE_API_BASE_URL=
# ENABLE_PDF_INDEX=true
# ENABLE_LLM=true
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# PORT=3001

# --- Hosted Production (With Backend) ---
# VITE_INSTRUCTOR_PASSCODE=YourSecurePasscode2024
# VITE_API_BASE_URL=https://api.sql-adapt.com
# VITE_ENABLE_PDF_INDEX=true
# VITE_ENABLE_LLM=true

# --- Static Hosting Only (Vercel/Netlify) ---
# VITE_INSTRUCTOR_PASSCODE=YourSecurePasscode2024
# VITE_API_BASE_URL=
# VITE_ENABLE_PDF_INDEX=false
# VITE_ENABLE_LLM=false

# ============================================
# E2E AUTH HARNESS (Playwright, optional)
# ============================================
# Deterministic deployed setup prefers login-first for instructor.
# Set E2E_ALLOW_INSTRUCTOR_SIGNUP=true only when you explicitly want
# setup:auth to attempt instructor signup fallback.
E2E_ALLOW_INSTRUCTOR_SIGNUP=false
# E2E_INSTRUCTOR_EMAIL=instructor-e2e@example.com
# E2E_INSTRUCTOR_PASSWORD=TestPassword123!
# E2E_STUDENT_CLASS_CODE=WJ2FR8KM
# E2E_INSTRUCTOR_CODE=TEACHSQL2026
# PLAYWRIGHT_BASE_URL=https://adaptive-instructional-artifacts.vercel.app
# PLAYWRIGHT_API_BASE_URL=https://adaptive-instructional-artifacts-ap.vercel.app
# VERCEL_AUTOMATION_BYPASS_SECRET=your_preview_bypass_secret
# PLAYWRIGHT_FRONTEND_SHARE_URL=https://your-preview.vercel.app/?_vercel_share=...
# PLAYWRIGHT_API_SHARE_TOKEN=...  # optional, enables API preflight against protected previews
