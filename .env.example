# SQL-Adapt Environment Variables

# =============================================================================
# Frontend Configuration (VITE_ prefix)
# =============================================================================

# Instructor passcode for accessing the instructor dashboard
# Change this to a secure value in production
VITE_INSTRUCTOR_PASSCODE=TeachSQL2024

# Base URL for backend API
# Leave empty for same-origin (development with Vite proxy)
# Set to your backend URL for production (e.g., https://api.sql-adapt.com)
VITE_API_BASE_URL=

# Enable PDF index feature flag (frontend)
# Set to true to enable PDF index UI components
VITE_ENABLE_PDF_INDEX=false

# Enable LLM feature flag (frontend)
# Set to true to enable LLM-powered AI hints UI
VITE_ENABLE_LLM=false

# =============================================================================
# Backend Configuration (Server)
# =============================================================================

# Server port (default: 3001)
PORT=3001

# CORS origin for frontend requests
# In development: http://localhost:5173
# In production: your frontend URL
CORS_ORIGIN=http://localhost:5173

# Node environment
NODE_ENV=development

# =============================================================================
# PDF Index Configuration
# =============================================================================

# Enable PDF index feature on backend
# Requires pdftotext (Poppler) to be installed
ENABLE_PDF_INDEX=false

# Directory for PDF index storage
# Default: apps/server/data/pdf-index
PDF_INDEX_DIR=./data/pdf-index

# Directory for source PDF files
# Default: apps/server/data/pdfs
PDF_SOURCE_DIR=./data/pdfs

# =============================================================================
# LLM Configuration
# =============================================================================

# Enable LLM proxy on backend
# When enabled, the backend will proxy LLM requests to Ollama
ENABLE_LLM=false

# Ollama base URL
# Default: http://127.0.0.1:11434 (local Ollama)
# Can be set to a remote Ollama instance for production
OLLAMA_BASE_URL=http://127.0.0.1:11434

# =============================================================================
# Deployment Examples
# =============================================================================

# --- Local Development (Full Features) ---
# VITE_INSTRUCTOR_PASSCODE=TeachSQL2024
# VITE_ENABLE_PDF_INDEX=true
# VITE_ENABLE_LLM=true
# ENABLE_PDF_INDEX=true
# ENABLE_LLM=true
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# --- Hosted Production (Backend + Frontend) ---
# VITE_API_BASE_URL=https://api.sql-adapt.com
# VITE_ENABLE_PDF_INDEX=true
# VITE_ENABLE_LLM=true
# ENABLE_PDF_INDEX=true
# ENABLE_LLM=true
# OLLAMA_BASE_URL=http://your-ollama-server:11434

# --- Static Hosting Only (Vercel/Netlify without backend) ---
# VITE_API_BASE_URL=
# VITE_ENABLE_PDF_INDEX=false
# VITE_ENABLE_LLM=false
