# SQL-Adapt Backend Server Configuration

# Server port
PORT=3001

# SQLite database file path (relative to server root)
DATABASE_PATH=./data/sql-adapt.db

# CORS allowed origin (frontend URL)
CORS_ORIGIN=http://localhost:5173

# Node environment
NODE_ENV=development

# Feature flags for hosted mode
# When deploying to Vercel or other hosted environments without local Ollama/PDF support,
# these endpoints will return 503 Service Unavailable with clear messaging
ENABLE_PDF_INDEX=false
ENABLE_LLM_PROXY=false
