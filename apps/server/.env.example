# SQL-Adapt Backend Server Environment Variables

# =============================================================================
# Server Configuration
# =============================================================================

# Server port (default: 3001)
PORT=3001

# CORS origin for frontend requests
# In development: http://localhost:5173
# In production: your frontend URL (e.g., https://sql-adapt.com)
CORS_ORIGIN=http://localhost:5173
# Optional explicit allowlist (comma-separated) for multiple frontend origins
# CORS_ORIGINS=https://app.example.com,https://www.example.com
# Optional wildcard allowlist for trusted preview domains
# CORS_ORIGIN_PATTERNS=https://your-project-*.vercel.app

# Node environment
NODE_ENV=development

# =============================================================================
# Database Configuration (Neon PostgreSQL)
# =============================================================================

# Neon PostgreSQL connection string (REQUIRED for production)
# Get your connection string from: https://neon.tech
# Format: postgresql://username:password@host/database?sslmode=require
DATABASE_URL=

# Alternative: Neon-specific environment variable
NEON_DATABASE_URL=

# Automatic schema initialization.
# initializeSchema() runs ~40 sequential CREATE TABLE/INDEX round-trips to Neon
# on every serverless cold start. Once the schema is provisioned out-of-band
# (run `npm run db:init:neon` once), set this to false to skip the per-cold-start
# init and reduce latency. Unset/any-other-value preserves auto-init (default).
# AUTO_SCHEMA_INIT=false

# =============================================================================
# Authentication Access Codes
# =============================================================================

# Required for production account signup flows
# Student accounts must provide this class code at signup.
STUDENT_SIGNUP_CODE=ClassSQL2026

# Instructor accounts must provide this code at signup.
INSTRUCTOR_SIGNUP_CODE=TeachSQL2026

# Auth/CSRF cookie SameSite + Secure attributes (sql_adapt_auth, sql_adapt_csrf).
# Defaults preserve prior behavior: production => SameSite=None; Secure (works
# cross-site), non-prod => SameSite=Lax; not Secure.
# Set SameSite=lax ONLY when the frontend calls the API on its own origin
# (Vercel rewrite + VITE_API_BASE_URL=same-origin). Flipping to lax while the
# frontend still calls a different backend host breaks auth for everyone.
# AUTH_COOKIE_SAMESITE=lax
# AUTH_COOKIE_SECURE=true

# =============================================================================
# Feature Flags
# =============================================================================

# Enable PDF index feature
# When enabled, allows PDF upload and indexing
# Requires pdftotext (Poppler) to be installed
ENABLE_PDF_INDEX=false

# Enable LLM proxy feature
# When enabled, proxies LLM requests to Ollama
ENABLE_LLM=false

# =============================================================================
# PDF Index Configuration
# =============================================================================

# Directory for PDF index storage
# Default: ./data/pdf-index
PDF_INDEX_DIR=./data/pdf-index

# Directory for source PDF files
# Default: ./data/pdfs
PDF_SOURCE_DIR=./data/pdfs

# =============================================================================
# LLM Configuration
# =============================================================================

# Ollama base URL
# Default: http://127.0.0.1:11434 (local Ollama)
# Can be set to a remote Ollama instance for production
OLLAMA_BASE_URL=http://127.0.0.1:11434

# LLM Provider Configuration
# Set to 'groq' for hosted LLM or 'ollama' for local LLM
LLM_PROVIDER=ollama

# Groq API Configuration (required when LLM_PROVIDER=groq)
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b

# =============================================================================
# Quick Start Examples
# =============================================================================

# --- Local Development (Full Features) ---
# PORT=3001
# CORS_ORIGIN=http://localhost:5173
# ENABLE_PDF_INDEX=true
# ENABLE_LLM=true
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# --- Production with Groq + Neon ---
# PORT=3001
# CORS_ORIGIN=https://sql-adapt.com
# DATABASE_URL=postgresql://...
# ENABLE_PDF_INDEX=false
# ENABLE_LLM=true
# LLM_PROVIDER=groq
# GROQ_API_KEY=your-groq-api-key
# GROQ_MODEL=openai/gpt-oss-20b

# --- Production with Remote Ollama ---
# PORT=3001
# CORS_ORIGIN=https://sql-adapt.com
# ENABLE_PDF_INDEX=true
# ENABLE_LLM=true
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://your-ollama-server:11434

# --- Minimal Mode (No AI Features) ---
# PORT=3001
# CORS_ORIGIN=http://localhost:5173
# ENABLE_PDF_INDEX=false
# ENABLE_LLM=false
