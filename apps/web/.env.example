# SQL-Adapt Frontend Environment Configuration

# Backend API URL (optional - leave empty to use localStorage only)
# For hosted deployments, set this to your deployed backend URL
VITE_API_URL=http://localhost:3001/api

# Use backend API instead of localStorage
VITE_USE_BACKEND=true

# Instructor passcode for role authentication
VITE_INSTRUCTOR_PASSCODE=TeachSQL2024

# LLM Configuration (optional)
# Set this to enable LLM-powered features (requires local Ollama)
# Leave unset for deterministic hosted mode
# VITE_LLM_URL=http://localhost:11434

# Note: When VITE_LLM_URL is not set, the app runs in deterministic mode
# using SQL-Engage templates instead of LLM generation
