# SQL-Adapt Frontend Environment Configuration
# =============================================================================
#
# IMPORTANT: VITE_* variables are EMBEDDED AT BUILD TIME on Vercel.
# They cannot be changed without redeploying.
#
# For local development, these variables are optional (sensible fallbacks exist).
# For hosted/Vercel deployment, VITE_INSTRUCTOR_PASSCODE is REQUIRED.
#
# See docs/DEPLOYMENT_MODES.md for full capability matrix.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED FOR HOSTED DEPLOYMENT
# -----------------------------------------------------------------------------
# Instructor passcode for role authentication.
# On Vercel: MUST be set at build time or instructor mode will be unavailable.
# On local dev: Falls back to allowing instructor selection without passcode.
VITE_INSTRUCTOR_PASSCODE=TeachSQL2024

# -----------------------------------------------------------------------------
# OPTIONAL: Backend API (Full-Stack Mode)
# -----------------------------------------------------------------------------
# Uncomment to enable backend API persistence instead of localStorage.
# This requires the backend server to be running (npm run server:dev).
#
# VITE_API_BASE_URL=http://localhost:3001

# Preferred textbook corpus source at runtime:
# - static: use bundled textbook-static assets
# - remote: prefer Neon-backed /api/corpus endpoints (falls back to static on failure)
# VITE_TEXTBOOK_CORPUS_MODE=remote

# -----------------------------------------------------------------------------
# OPTIONAL: Local Ollama URL
# -----------------------------------------------------------------------------
# Optional direct Ollama URL for local development.
# Hosted full-stack deployments should use VITE_API_BASE_URL and let the backend
# choose the active provider (Groq in production, Ollama in local dev if desired).
#
# VITE_OLLAMA_URL=http://localhost:11434

# -----------------------------------------------------------------------------
# OPTIONAL: PDF Index Features (Local Development Only)
# -----------------------------------------------------------------------------
# Enable PDF search and "Ask My Textbook" chat features.
# NOTE: PDF features are DISABLED on hosted/Vercel deployments regardless
# of this setting. They require local backend with Poppler installed.
#
# VITE_ENABLE_PDF_INDEX=true

# -----------------------------------------------------------------------------
# LLM Configuration
# -----------------------------------------------------------------------------
# The frontend auto-detects the backend provider from /api/llm/status.
# No frontend provider flag is required for Groq mode.

# -----------------------------------------------------------------------------
# DEPLOYMENT MODE DETECTION
# -----------------------------------------------------------------------------
# The app automatically detects hosted mode via:
# - Presence of VERCEL or NETLIFY environment variables
# - Production build without backend API configured
#
# When in frontend-only hosted mode:
# - LLM features use deterministic templates
# - PDF features are disabled
# - All data persists to localStorage (no backend required)
# - Research dashboard uses deterministic replay
#
# When VITE_API_BASE_URL is configured:
# - The app treats the deployment as hosted full-stack mode
# - Live LLM availability comes from the backend /api/llm/status endpoint
# - Groq-backed Vercel deployments are supported
#
# See docs/DEPLOYMENT_MODES.md for complete feature matrix.
# =============================================================================
