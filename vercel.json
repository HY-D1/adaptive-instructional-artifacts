{
  "_comment": "SQL-Adapt Vercel Configuration",
  "_note": "For full features with LLM/PDF, deploy the backend server separately.",
  "_note2": "Set VITE_API_BASE_URL to your backend URL for API features.",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/index.html" },
    { "source": "/ollama/(.*)", "destination": "/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/sql-wasm.wasm",
      "headers": [
        { "key": "Content-Type", "value": "application/wasm" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
